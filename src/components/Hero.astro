<section id="about">
  <div class="container">
    <div class="hero-grid">

      <div class="hero-avatar fu fu-1">
        <div class="avatar-ring">
          <img
            class="avatar-img"
            src="/assets/img/avatars/2%20-%20PicturePeople-2.jpg"
            alt="Marcel Matschke"
            width="260"
            height="260"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>

      <p class="hero-eyebrow fu fu-2">Hey, ich bin</p>

      <h1 class="hero-name fu fu-3">Marcel<br/>Matschke</h1>

      <div class="hero-rule fu fu-4">
        <span class="hero-rule-line"></span>
        <span class="hero-role">Software Entwickler &middot; Kassel</span>
      </div>

      <p class="hero-bio fu fu-5">
        Vater, ein bisschen Nerd und leidenschaftlicher Entwickler.<br/>
        Ich baue Dinge, die funktionieren&nbsp;&ndash; und manchmal sogar gut aussehen.
      </p>

      <div class="hero-cta fu fu-6">
        <a class="btn btn--primary" href="mailto:marcel@matschke.dev">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"
            viewBox="0 0 24 24" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          Kontakt aufnehmen
        </a>
      </div>

    </div>
  </div>
</section>
